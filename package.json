{
  "name": "rtbo-website-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Workspace scripts for the RTBO React + PHP website.",
  "scripts": {
    "audit:source": "node tools/audit-rtbo-source-integrity.mjs && node tools/audit-refzone-test-banks.mjs",
